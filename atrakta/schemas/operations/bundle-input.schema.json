{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atrakta/schemas/operations/bundle-input.schema.json",
  "title": "BundleInput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "layer_item",
    "guidance_items",
    "projection_source",
    "failure_class",
    "failure_context",
    "mutation_target",
    "legacy_asset",
    "operation_input",
    "extension_items",
    "portability_input",
    "audit_input",
    "strict_input"
  ],
  "properties": {
    "layer_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "schema_id"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "schema_id": { "type": "string", "minLength": 1 }
      }
    },
    "guidance_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 }
        }
      }
    },
    "projection_source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "minLength": 1 }
      }
    },
    "failure_class": { "type": "string", "minLength": 1 },
    "failure_context": {
      "type": "object",
      "additionalProperties": true,
      "required": ["scope"],
      "properties": {
        "scope": { "type": "string", "minLength": 1 }
      }
    },
    "mutation_target": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "legacy_asset": {
      "type": "object",
      "additionalProperties": true,
      "required": ["asset_id", "ownership", "freshness", "canonical_mapping"],
      "properties": {
        "asset_id": { "type": "string", "minLength": 1 },
        "ownership": { "type": "string", "minLength": 1 },
        "freshness": { "type": "string", "minLength": 1 },
        "canonical_mapping": { "type": "string", "minLength": 1 }
      }
    },
    "operation_input": {
      "type": "object",
      "additionalProperties": true,
      "required": ["command_or_alias"],
      "properties": {
        "command_or_alias": { "type": "string", "minLength": 1 }
      }
    },
    "extension_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "kind"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 }
        }
      }
    },
    "portability_input": {
      "type": "object",
      "additionalProperties": true,
      "required": ["interface_id", "requested_targets", "available_sources", "binding_capabilities", "degrade_policy"],
      "properties": {
        "interface_id": { "type": "string", "minLength": 1 },
        "requested_targets": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "available_sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "binding_capabilities": {
          "type": "object",
          "additionalProperties": true,
          "required": ["id", "approval_channel", "portability_mode"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "approval_channel": { "type": "string", "minLength": 1 },
            "portability_mode": { "type": "string", "minLength": 1 }
          }
        },
        "degrade_policy": { "type": "string", "minLength": 1 }
      }
    },
    "audit_input": {
      "type": "object",
      "additionalProperties": true,
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "minLength": 1 }
      }
    },
    "strict_input": {
      "type": "object",
      "additionalProperties": true,
      "required": ["current_state", "scope"],
      "properties": {
        "current_state": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 }
      }
    }
  }
}
