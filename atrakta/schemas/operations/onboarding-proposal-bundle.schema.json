{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atrakta/schemas/operations/onboarding-proposal-bundle.schema.json",
  "title": "OnboardingProposalBundle",
  "type": "object",
  "required": [
    "detected_assets",
    "detected_risks",
    "inferred_mode",
    "inferred_managed_scope",
    "inferred_capabilities",
    "inferred_guidance_strength",
    "inferred_default_policy",
    "inferred_failure_routing",
    "conflicts",
    "suggested_next_actions"
  ],
  "properties": {
    "detected_assets": { "type": "array", "items": { "type": "string" } },
    "detected_risks": { "type": "array", "items": { "type": "string" } },
    "inferred_mode": { "type": "string", "enum": ["new_project", "brownfield_project"] },
    "inferred_managed_scope": { "type": "object", "additionalProperties": true },
    "inferred_capabilities": { "type": "array", "items": { "type": "string" } },
    "inferred_guidance_strength": { "type": "object", "additionalProperties": true },
    "inferred_default_policy": { "type": "object", "additionalProperties": true },
    "inferred_failure_routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failure_class",
        "scope",
        "triggers",
        "default_tier",
        "resolved_tier",
        "strict_transition",
        "requires_human_review",
        "execution_allowed",
        "projection_allowed",
        "next_allowed_action"
      ],
      "properties": {
        "failure_class": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "enum": ["request", "task", "workspace"] },
        "triggers": { "type": "array", "items": { "type": "string" } },
        "default_tier": {
          "type": "string",
          "enum": ["BLOCK", "DEGRADE_TO_STRICT", "PROPOSAL_ONLY", "WARN_ONLY"]
        },
        "resolved_tier": {
          "type": "string",
          "enum": ["BLOCK", "DEGRADE_TO_STRICT", "PROPOSAL_ONLY", "WARN_ONLY"]
        },
        "strict_transition": { "type": "string", "enum": ["none", "guarded", "strict"] },
        "requires_human_review": { "type": "boolean" },
        "execution_allowed": { "type": "boolean" },
        "projection_allowed": { "type": "boolean" },
        "next_allowed_action": {
          "type": "string",
          "enum": ["inspect", "preview", "simulate", "propose", "apply", "deny"]
        }
      }
    },
    "conflicts": { "type": "array", "items": { "type": "string" } },
    "suggested_next_actions": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
