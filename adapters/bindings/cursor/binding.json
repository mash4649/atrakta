{
  "id": "cursor",
  "kind": "ide_binding",
  "surfaces": [
    "tool_hint",
    "diagnostics",
    "autostart"
  ],
  "projection_targets": [
    "ide_rules",
    "repo_docs"
  ],
  "ingest_sources": [
    "canonical_policy",
    "repo_docs",
    "agents_md",
    "ide_rules",
    "skill_asset"
  ],
  "approval_channel": "prompt",
  "portability_mode": "semantic_best_effort",
  "can_mutate_core_contract": false,
  "install_path": ".atrakta/wrap/cursor.sh",
  "script_template": "#!/usr/bin/env sh\n# managed by atrakta wrap install\n# tool_id: {{tool_id}}\n# project_root: {{project_root}}\n# capabilities: {{capabilities_csv}}\nexec atrakta start \"$@\"\n",
  "capabilities": [
    "install",
    "run"
  ],
  "autostart_config": {
    "kind": "cursor_autostart",
    "path": ".cursor/autostart.json",
    "command": "atrakta start",
    "format": "json"
  }
}
