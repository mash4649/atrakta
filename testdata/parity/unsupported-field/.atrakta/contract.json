{
  "v": 1,
  "project_id": "fixture-unsupported-field",
  "interfaces": {
    "supported": [
      "vscode",
      "cursor",
      "windsurf",
      "trae",
      "antigravity",
      "aider",
      "codex_cli",
      "gemini_cli",
      "claude_code",
      "opencode",
      "github_copilot"
    ],
    "fallback": "core",
    "core_set": [
      "cursor"
    ],
    "prune_unused_default": true
  },
  "boundary": {
    "include": [
      ""
    ],
    "exclude": [
      ".atrakta/"
    ],
    "managed_root": ".atrakta/"
  },
  "tools": {
    "allow": [
      "create",
      "edit",
      "run"
    ],
    "deny": [],
    "approval_required_for": [
      "boundary_expand",
      "external_side_effect",
      "destructive_prune"
    ]
  },
  "token_budget": {
    "soft": 8000,
    "hard": 16000
  },
  "quality": {
    "quick_checks": [
      "projection_integrity"
    ],
    "heavy_checks": [
      "go_test_compile"
    ],
    "enable_heavy": false
  },
  "projections": {
    "optional_templates": {
      "cursor": [
        "cursor-rule",
        "unsupported-template"
      ]
    },
    "max_per_interface": 3
  },
  "routing": {
    "categories": {
      "edit": {
        "worker": "code_edit_fast",
        "quality": "quick"
      },
      "sync": {
        "worker": "sync_safe",
        "quality": "quick"
      },
      "verify": {
        "worker": "ci_strict",
        "quality": "heavy"
      }
    },
    "default": {
      "worker": "general",
      "quality": "quick"
    }
  },
  "context": {
    "resolution": "nearest_with_import",
    "projection": "interface_only",
    "max_import_depth": 6
  },
  "security": {
    "profile": "workspace_write"
  },
  "edit_safety": {
    "mode": "anchor+optional_ast",
    "anchors": {
      "normalization": "ws+eol+unicode_nfc",
      "window_lines": 20
    },
    "languages": {
      "go": "ast",
      "json": "parse"
    }
  },
  "policies": {
    "prompt_min": {
      "ref": ".atrakta/policies/prompt-min.json",
      "apply": "conditional"
    }
  },
  "parity": {
    "v": 1,
    "canonical_sources": [
      ".atrakta/contract.json",
      ".atrakta/state.json",
      ".atrakta/events.jsonl"
    ],
    "instruction_surface": {
      "source": "contract_and_policy",
      "prompt_policy_ref": "policies.prompt_min.ref"
    },
    "approval_surface": {
      "approval_required_for_ref": "tools.approval_required_for"
    },
    "output_surface": {
      "plan_format": "markdown",
      "error_format": "structured"
    },
    "execution_surface": {
      "path_policy": "fast_first_strict_on_demand",
      "latest_only": true
    },
    "quality_surface": {
      "quick_checks_ref": "quality.quick_checks",
      "heavy_checks_ref": "quality.heavy_checks"
    },
    "safety_surface": {
      "security_profile_ref": "security.profile"
    },
    "routing_surface": {
      "categories_ref": "routing.categories",
      "default_ref": "routing.default"
    },
    "projection_surface": {
      "deterministic": true,
      "managed_only_repair": true
    }
  },
  "extensions": {
    "v": 1,
    "merge_mode": "append-first",
    "agents": {
      "mode": "append",
      "append_file": ".atrakta/AGENTS.append.md"
    },
    "mcp": [],
    "plugins": [],
    "skills": [],
    "workflows": [],
    "hooks": {}
  }
}
