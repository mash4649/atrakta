{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atrakta/schemas/core/decision.schema.json",
  "title": "CoreDecision",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision_id", "request_id", "resolver", "decision", "reason", "next_allowed_action"],
  "properties": {
    "decision_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "resolver": { "type": "string", "minLength": 1 },
    "decision": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "next_allowed_action": {
      "type": "string",
      "enum": ["inspect", "preview", "simulate", "propose", "apply", "deny"]
    }
  }
}
