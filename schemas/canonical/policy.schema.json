{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atrakta/schemas/canonical/policy.schema.json",
  "title": "CanonicalPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": ["policy_id", "strength", "surfaces", "effect", "precedence"],
  "properties": {
    "policy_id": { "type": "string", "minLength": 1 },
    "strength": {
      "type": "string",
      "enum": [
        "authoritative_constraint",
        "orchestration_constraint",
        "executable_guidance",
        "advisory_map",
        "tool_hint"
      ]
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["decision", "orchestration", "mutation", "projection", "diagnostics"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "effect": { "type": "string", "enum": ["allow", "deny", "proposal_only", "strict"] },
    "precedence": { "type": "integer", "minimum": 1 }
  }
}
