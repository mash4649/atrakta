{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atrakta/schemas/extension/extension-binding.schema.json",
  "title": "ExtensionBinding",
  "type": "object",
  "required": ["binding_id", "kind", "order"],
