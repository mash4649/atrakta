{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atrakta/schemas/extension/plugin-sdk.schema.json",
  "title": "PluginSDKDefinition",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "kind",
    "targets",
    "entrypoint",
    "capabilities",
    "permissions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "plugin-sdk.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "const": "plugin"
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "adapter",
          "projection",
          "operations"
        ]
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "entrypoint": {
      "type": "object",
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "binary",
            "go-package"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "required": [
        "can_mutate_core_contract",
        "can_write_canonical",
        "can_block_execution"
      ],
      "properties": {
        "can_mutate_core_contract": {
          "type": "boolean",
          "const": false
        },
        "can_write_canonical": {
          "type": "boolean",
          "const": false
        },
        "can_block_execution": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "homepage": {
          "type": "string"
        },
        "license": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
