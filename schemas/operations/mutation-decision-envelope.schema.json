{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atrakta/schemas/operations/mutation-decision-envelope.schema.json",
  "title": "MutationDecisionEnvelope",
  "type": "object",
  "required": [
    "decision_id",
    "phase",
    "target_path",
    "scope",
    "policy",
    "allowed_modes",
    "requested_action",
    "allowed",
    "reason",
    "evidence",
    "next_allowed_action"
  ],
  "properties": {
    "decision_id": { "type": "string", "minLength": 1 },
    "phase": { "type": "string", "enum": ["inspect", "propose", "apply"] },
    "target_path": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "minLength": 1 },
    "policy": { "type": "string", "minLength": 1 },
    "allowed_modes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "requested_action": { "type": "string", "minLength": 1 },
    "allowed": { "type": "boolean" },
    "reason": { "type": "string", "minLength": 1 },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "next_allowed_action": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
