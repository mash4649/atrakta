{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atrakta/schemas/operations/start-latency-benchmark.schema.json",
  "title": "StartLatencyBenchmarkReport",
  "type": "object",
  "required": [
    "schema_version",
    "scenario",
    "command",
    "interface_id",
    "project_root",
    "iterations",
    "samples",
    "average_ms",
    "min_ms",
    "max_ms",
    "median_ms",
    "fast_path_hits"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "scenario": { "type": "string", "minLength": 1 },
    "command": { "type": "string", "minLength": 1 },
    "interface_id": { "type": "string", "minLength": 1 },
    "project_root": { "type": "string", "minLength": 1 },
    "iterations": { "type": "integer", "minimum": 1 },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["iteration", "duration_ms", "exit_code", "fast_path"],
        "properties": {
          "iteration": { "type": "integer", "minimum": 1 },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "exit_code": { "type": "integer" },
          "fast_path": { "type": "boolean" },
          "result_path": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "average_ms": { "type": "integer", "minimum": 0 },
    "min_ms": { "type": "integer", "minimum": 0 },
    "max_ms": { "type": "integer", "minimum": 0 },
    "median_ms": { "type": "integer", "minimum": 0 },
    "fast_path_hits": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
