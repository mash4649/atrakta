{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atrakta/schemas/operations/bundle-output.schema.json",
  "title": "BundleOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "steps", "final_allowed_action"],
  "properties": {
    "mode": { "type": "string", "enum": ["inspect", "preview", "simulate"] },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "output"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "output": { "type": "object" }
        }
      }
    },
    "final_allowed_action": {
      "type": "string",
      "enum": ["inspect", "preview", "simulate", "propose", "apply", "deny"]
    }
  }
}
